# Copy this file to .env and put your keys here.
# Without a key, the matching mode works with mock (fake) data.

# Trains (Trafikverket). Get a free key from:
# https://api.trafikinfo.trafikverket.se/Account/Register
TRAFIKVERKET_API_KEY=

# Public transport — bus / metro / tram (Trafiklab ResRobot v2.1).
# Register a free project + key at: https://www.trafiklab.se/api/trafiklab-apis/resrobot-v21/
RESROBOT_API_KEY=

PORT=3100
